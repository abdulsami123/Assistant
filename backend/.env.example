# Runtime environment: `development` relaxes some checks; `production` enforces CORS allowlists and disables docs by default.
ENV=development

# Comma-separated browser origins allowed by CORS. Never use `*` with credentials (this API does not use cookies).
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional override for Groq OpenAI-compatible base URL.
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Force OpenAPI docs (`/docs`, `/openapi.json`) on or off regardless of environment.
# When unset, docs are enabled in development and disabled in production.
# EXPOSE_DOCS=true
