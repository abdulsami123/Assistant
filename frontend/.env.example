# Absolute origin of the TwinMind FastAPI server, without a trailing slash.
# Leave empty during local development to rely on Vite's dev proxy (`/api` → backend).
#
# Production builds must set this to the public API origin unless the UI is hosted
# on the same site as the API (same-origin `/api/v1` routing behind a reverse proxy).
VITE_API_URL=

# Optional: override the backend target used by the Vite dev server proxy (defaults to http://127.0.0.1:8000).
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
